{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Phoenix AI tool submission",
  "type": "object",
  "required": ["id", "slug", "title", "status", "positioning", "available_now", "demo_url", "primary_cta", "owner", "last_verified"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 2 },
    "status": { "enum": ["公開沙盒示範", "受邀 Demo", "PoC 招募中", "導入評估中"] },
    "positioning": { "type": "string", "minLength": 10 },
    "audience": { "type": "array", "items": { "type": "string" } },
    "available_now": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "poc_configurable": { "type": "array", "items": { "type": "string" } },
    "implementation_assessment": { "type": "array", "items": { "type": "string" } },
    "demo_url": { "type": "string", "minLength": 1 },
    "primary_cta": { "$ref": "#/$defs/cta" },
    "secondary_cta": { "$ref": "#/$defs/cta" },
    "poc_success_criteria": { "type": "array", "items": { "type": "string" } },
    "owner": { "type": "string", "minLength": 1 },
    "last_verified": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  },
  "$defs": {
    "cta": {
      "type": "object",
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string", "minLength": 2 },
        "url": { "type": "string", "minLength": 1 }
      }
    }
  }
}
